---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Bella | Salon Fryzjerski w Łodzi">
	<main class="min-h-screen bg-rose-50 text-neutral-900">
		<section class="bg-gradient-to-br from-rose-100 via-white to-amber-50">
			<div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
				<p class="mb-4 inline-block rounded-full bg-rose-200 px-4 py-1 text-sm font-semibold tracking-wide text-rose-900">
					Salon Bella - Łódź
				</p>
				<h1 class="max-w-3xl text-4xl font-bold leading-tight md:text-6xl">
					Twoje wlosy w najlepszych rekach.
				</h1>
				<p class="mt-6 max-w-2xl text-lg text-neutral-700">
					W Bella tworzymy fryzury, ktore podkreslaja Twoj styl. Strzyzenie, koloryzacja i pielegnacja
					w przyjaznej atmosferze, w samym sercu Lodzi.
				</p>
				<a
					href="#kontakt"
					class="mt-10 inline-flex rounded-full bg-rose-600 px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-rose-700"
				>
					Umow wizyte
				</a>
			</div>
		</section>

		<section id="uslugi" class="mx-auto max-w-6xl px-6 py-20">
			<div class="mb-10">
				<h2 class="text-3xl font-bold md:text-4xl">Nasze uslugi</h2>
				<p class="mt-3 text-neutral-700">Profesjonalna obsluga dopasowana do Twoich potrzeb.</p>
			</div>
			<div class="grid gap-6 md:grid-cols-3">
				<article class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-rose-100">
					<h3 class="text-xl font-semibold">Strzyzenie damskie i meskie</h3>
					<p class="mt-3 text-neutral-700">
						Precyzyjne ciecie i stylizacja dobrane do ksztaltu twarzy oraz codziennej pielegnacji.
					</p>
				</article>
				<article class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-rose-100">
					<h3 class="text-xl font-semibold">Koloryzacja i baleyage</h3>
					<p class="mt-3 text-neutral-700">
						Nowoczesne techniki koloryzacji, od subtelnych refleksow po pelna metamorfoze.
					</p>
				</article>
				<article class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-rose-100">
					<h3 class="text-xl font-semibold">Pielegnacja i regeneracja</h3>
					<p class="mt-3 text-neutral-700">
						Zabiegi odbudowujace, ktore przywracaja blask, miekkosc i zdrowy wyglad wlosow.
					</p>
				</article>
			</div>
		</section>

		<section id="kontakt" class="bg-neutral-900 py-20 text-white">
			<div class="mx-auto max-w-6xl px-6">
				<h2 class="text-3xl font-bold md:text-4xl">Kontakt</h2>
				<p class="mt-4 max-w-2xl text-neutral-300">
					Chcesz zarezerwowac termin? Zadzwon do nas i wybierz dogodna godzine wizyty.
				</p>
				<p class="mt-8 text-2xl font-semibold">
					Telefon:
					<a href="tel:+48421234567" class="text-rose-300 transition hover:text-rose-200">+48 42 123 45 67</a>
				</p>
			</div>
		</section>
	</main>
</Layout>
